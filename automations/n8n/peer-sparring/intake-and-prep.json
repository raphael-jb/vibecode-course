    {
      "parameters": {
        "jsCode": "const fs = require('fs');\nconst path = require('path');\nconst cfg = $('Runtime Config').first().json;\nconst promptText = fs.readFileSync(path.join(cfg.repoPath, cfg.prepPromptPath), 'utf8');\nconst payload = $('Validate Payload').first().json;\nconst caseRow = $('Insert Case').first().json[0];\nconst folder = $('Create Drive Folder').first().json;\nconst caseBriefJson = JSON.stringify(payload.case_brief, null, 2);\nconst rendered = promptText\n  .replace('{{client_name}}', payload.client.name)\n  .replace('{{case_title}}', payload.case_title)\n  .replace('{{case_brief_json}}', caseBriefJson);\nreturn [{ json: {\n  prompt: rendered,\n  case_id: caseRow.case_id,\n  case_title: payload.case_title,\n  client_name: payload.client.name,\n  client_email: payload.client.email,\n  folder_id: folder.id || folder.fileId || folder.folderId\n} }];"
      },
