    {
      "parameters": {
        "jsCode": "// Validate intake payload against docs/peer-sparring/intake-payload-contract.md\nconst raw = $('Intake Webhook').first().json.body || $('Intake Webhook').first().json;\nconst errors = [];\nfunction str(value) { return typeof value === 'string' ? value : ''; }\nfunction trimmed(value) { return str(value).trim(); }\nconst client = raw.client || {};\nconst brief = raw.case_brief || {};\nconst consent = raw.consent || {};\nconst name = trimmed(client.name);\nconst email = trimmed(client.email).toLowerCase();\nif (name.length < 2 || name.length > 120) errors.push({ field: 'client.name', rule: 'length_2_120' });\nif (!/^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/.test(email)) errors.push({ field: 'client.email', rule: 'email_format' });\nconst long = ['konkreter_anlass', 'entscheidung_oder_spannung'];\nfor (const key of long) {\n  if (trimmed(brief[key]).length < 30) errors.push({ field: `case_brief.${key}`, rule: 'min_length', expected: 30 });\n}\nconst short = ['beteiligte', 'bisher_versucht', 'gutes_ergebnis'];\nfor (const key of short) {\n  if (trimmed(brief[key]).length < 3) errors.push({ field: `case_brief.${key}`, rule: 'min_length', expected: 3 });\n}\nif (!['offline', 'live', 'online'].includes(raw.session_mode)) errors.push({ field: 'session_mode', rule: 'enum' });\nif (consent.data_processing !== true) errors.push({ field: 'consent.data_processing', rule: 'must_be_true' });\nif (errors.length) {\n  return [{ json: { valid: false, status: 400, body: { ok: false, error: 'validation_failed', details: errors } } }];\n}\nconst case_brief = {\n  konkreter_anlass: trimmed(brief.konkreter_anlass),\n  entscheidung_oder_spannung: trimmed(brief.entscheidung_oder_spannung),\n  beteiligte: trimmed(brief.beteiligte),\n  bisher_versucht: trimmed(brief.bisher_versucht),\n  gutes_ergebnis: trimmed(brief.gutes_ergebnis),\n  dringlichkeit: trimmed(brief.dringlichkeit) || null,\n  constraints: trimmed(brief.constraints) || null,\n  aktuelle_hypothese: trimmed(brief.aktuelle_hypothese) || null,\n  optionaler_kontext: trimmed(brief.optionaler_kontext) || null\n};\nlet case_title = case_brief.konkreter_anlass.slice(0, 60).trim();\ncase_title = case_title.replace(/[\\s,;:.!?\\-—]+$/u, '');\nreturn [{ json: { valid: true, client: { name, email }, case_brief, case_title, session_mode: raw.session_mode, consent: { data_processing: !!consent.data_processing, marketing: !!consent.marketing }, submitted_at: raw.submitted_at || new Date().toISOString() } }];"
      },
